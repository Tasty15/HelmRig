<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.helmrig.overlord</string>
    <key>ProgramArguments</key>
    <array>
        <string>__ROOT_DIR__/.venv/bin/python3</string>
        <string>__ROOT_DIR__/agents/.overlord/overlord.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__ROOT_DIR__/agents</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__ROOT_DIR__/agents/.overlord/watchdog.log</string>
    <key>StandardErrorPath</key>
    <string>__ROOT_DIR__/agents/.overlord/watchdog.log</string>
</dict>
</plist>
