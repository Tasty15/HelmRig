# HelmRig — API-nycklar
# Skapa din .env med: cp .env.example .env

# Välj minst EN AI-leverantör:
DEEPSEEK_API_KEY=sk-din-nyckel-här
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# OPENROUTER_API_KEY=...

# E-post för felnotifikationer (via Composio Gmail — kräver: composio add gmail)
ALERT_EMAIL_TO=din-email@example.com

# Dashboard-säkerhet (valfritt)
# DASHBOARD_TOKEN=hemligt-token
